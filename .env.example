# Genesis Content OS — example environment
# Copy to .env and fill in. Or push to Doppler config (recommended).
# Never commit .env with real values.

# === Supabase (free tier OK to start) ===
SUPABASE_GENESIS_URL=https://your-project.supabase.co
SUPABASE_GENESIS_ANON_KEY=
SUPABASE_GENESIS_SERVICE_KEY=

# === OpenAI ===
OPENAI_API_KEY=

# === ElevenLabs (voice generation) ===
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# === HeyGen (avatar video) ===
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=

# === Telegram bot ===
TELEGRAM_BOT_TOKEN=
# Numeric chat ID for system alerts (your own DM)
TELEGRAM_TARGET_CHAT=
# @handle or numeric ID for the public channel that gets announcements
TELEGRAM_PUBLIC_CHANNEL=
TELEGRAM_PUBLIC_CHANNEL_ID=

# === Ghost blog ===
# Format: <keyId>:<keySecret>
GHOST_ADMIN_KEY=
GHOST_API_URL=https://your-blog.example.com

# === LinkedIn (Marketing Developer Platform required) ===
LINKEDIN_TOKEN=
# Format: urn:li:person:XXXXX
LINKEDIN_PERSON_URN=

# === GitHub (for trend scanner) ===
GITHUB_PAT=

# === n8n ===
N8N_API_KEY=
N8N_BASE_URL=http://localhost:5678
# n8n credential IDs (set after you create credentials in n8n UI)
N8N_CRED_SUPABASE_ID=
N8N_CRED_OPENAI_ID=
N8N_CRED_TELEGRAM_ID=

# === Plausible (analytics) ===
PLAUSIBLE_TOKEN=
PLAUSIBLE_SITE_ID=

# === ContentMachine receiver (optional, for video render pipeline) ===
RECEIVER_BASE_URL=https://your-receiver.example.com
RECEIVER_SECRET=
CONTENT_MACHINE_RUNS_DIR=/tmp/runs

# === Author identity (used in generated articles) ===
AUTHOR_NAME=Your Name
AUTHOR_URL=https://example.com
AUTHOR_BIO=Short author bio used in article system prompt.
BLOG_BASE_URL=https://example.com/blog
